---
const { title } = Astro.props;
---
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<title>{title} | Ô Fleurs</title>
		<style>
			nav { background: #f4f4f4; padding: 1rem; display: flex; gap: 20px; }
			nav a { text-decoration: none; color: #333; font-weight: bold; }
			body { font-family: sans-serif; margin: 0; }
			main { padding: 2rem; }
		</style>
	</head>
	<body>
		<nav>
			<a href="/">Accueil</a>
			<a href="/boutique">Boutique</a>
			<a href="/contact">Qui sommes-nous / Contact</a>
		</nav>
		<main>
			<slot /> <!-- C'est ici que le contenu de chaque page s'affichera -->
		</main>
	</body>
</html>