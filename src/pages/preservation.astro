---
import MainLayout from '../layouts/Mainlayout.astro';
import prods from '../data/produits_preservation_slider.json';
const produits = prods;
---
<MainLayout title="Préservations de bouquets">
  
  <div class="grille-produits-verticale">
    {produits.map((item) => (
      <div class="product-wrapper-vertical">
        
        <h2 class="product-title">{item.nom}</h2>

        <!-- CARROUSEL : Reprise exacte des classes de la page d'accueil -->
        <div class="carousel-container" data-carousel>
          
          <div class="carousel-display">
            {item.images && item.images.map((img, idx) => (
              <div class={`carousel-slide ${idx === 0 ? 'active' : ''}`}>
                <img src={img} alt={item.nom} loading="lazy" />
              </div>
            ))}
          </div>
          
          {/* Flèches et indicateurs (uniquement si plus d'une photo) */}
          {item.images && item.images.length > 1 && (
            <>
              <button class="carousel-arrow prev-btn" aria-label="Précédent">&#10094;</button>
              <button class="carousel-arrow next-btn" aria-label="Suivant">&#10095;</button>

              <div class="carousel-indicators">
                {item.images.map((_, idx) => (
                  <span class={`indicator-dot ${idx === 0 ? 'active' : ''}`} data-index={idx}></span>
                ))}
              </div>
            </>
          )}
        </div>
        
        <div class="product-action-vertical">
          <a href="/contact" class="btn-panier btn-contact-vertical">
            SUR DEVIS <br /> ME CONTACTER
          </a>
        </div>

        <div class="product-description-vertical">
          <p><strong>Que faire de mon bouquet après mon mariage ?</strong><br/>
          C'est la question que se posent beaucoup de mariées ! On souhaiterait le garder frais pour toujours, ne jamais le voir faner... Alors on le suspend pour qu'il sèche... Et prenne la poussière dans un vase en ayant perdu toutes ses couleurs.</p>

          <p>Si je vous disais qu'il existe une autre solution ? Ô fleurs vous propose de récupérer votre bouquet pour le rendre éternel ! Les fleurs seront patiemment pressées, parfois restaurées si leur état le nécessite, pour être ensuite encadrées dans le cadre que vous aurez choisi.</p>
          
          <p>Le pressage est un processus qui demande du temps. Les fleurs sont sèches après 3 semaines environ. Il faut donc compter un délai d'un mois environ pour récupérer votre cadre.</p>
          
          <p class="warning-box"><strong>ATTENTION !</strong><br/>
          Je ne propose pas d'envoi pour ce produit. Je récupère vos bouquets gratuitement dans un rayon de 10km autour de Rousset (13790), au-delà un supplément s'applique.</p>
          
          <p class="steps-title"><strong>Comment ça se passe ?</strong></p>

          <p>⚘️ Contactez moi via téléphone, mail, Facebook ou Instagram pour que l'on discute de votre projet, du type de cadre à utiliser, du format, et de la date de récupération de votre bouquet.</p>

          <p>⚘️ Vous souhaitez un autre type de cadre ? Un autre format ? Une personnalisation avec inclusion de photo ou faire part? Contactez moi, tout est possible 😊</p>

          <p>⚘️ Le jour J, je récupère votre bouquet à un point de rdv donné.</p>

          <p>⚘️ Pendant les 3 semaines suivantes, je chouchoute vos fleurs et je reviens vers vous pour vous proposer un design.</p>

          <p>⚘️ 🥳 Votre cadre est prêt ! On se donne rdv pour que vous le récupériez !</p>

          <p class="final-question">Vous avez des questions ? Une demande particulière ?<br/>
          Contactez moi ! Je me ferais un plaisir de répondre à vos demandes 😊</p>
          
          <p class="price-notice"><em>PRIX SUR DEVIS</em></p>
        </div>
      </div>
    ))}
  </div>
</MainLayout>

<script>
  // On cible uniquement les carrousels de la page via [data-carousel]
  const carousels = document.querySelectorAll('[data-carousel]');

  carousels.forEach((carousel) => {
    const slides = carousel.querySelectorAll('.carousel-slide');
    const nextBtn = carousel.querySelector('.next-btn');
    const prevBtn = carousel.querySelector('.prev-btn');
    const dots = carousel.querySelectorAll('.indicator-dot');
    let currentIndex = 0;

    if (slides.length <= 1) return;

    function showSlide(index: number) {
      if (index >= slides.length) {
        currentIndex = 0;
      } else if (index < 0) {
        currentIndex = slides.length - 1;
      } else {
        currentIndex = index;
      }

      // Active la bonne image
      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === currentIndex);
      });

      // Active le bon point
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    if (nextBtn) nextBtn.addEventListener('click', () => showSlide(currentIndex + 1));
    if (prevBtn) prevBtn.addEventListener('click', () => showSlide(currentIndex - 1));

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const idx = parseInt(target.dataset.index || '0');
        showSlide(idx);
      });
    });
  });
</script>